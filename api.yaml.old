apiVersion: apps/v1
kind: Deployment
metadata:
  name: api
  namespace: skymap
spec:
  replicas: 1
  selector:
    matchLabels:
      app: api
  template:
    metadata:
      labels:
        app: api
    spec:
      containers:
        - name: api
          image: sky_map-api:latest
          imagePullPolicy: Never
          command: ["python", "manage.py", "runserver", "0.0.0.0:8000"]
          ports:
            - containerPort: 8000
          env:
            - name: PYTHONDONTWRITEBYTECODE
              value: "1"
            - name: PYTHONUNBUFFERED
              value: "1"
            - name: MYSQL_HOST
              value: db
            - name: MYSQL_PORT
              value: "3306"
            - name: MYSQL_DATABASE
              value: sky_map
            - name: MYSQL_USER
              value: sky
            - name: MYSQL_PASSWORD
              value: changeme
---
apiVersion: v1
kind: Service
metadata:
  name: api
  namespace: skymap
spec:
  selector:
    app: api
  ports:
    - port: 8000
      targetPort: 8000

